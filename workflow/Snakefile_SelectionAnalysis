# =============================================================================
# Group level Selection analyses
# =============================================================================

rule RELAX:
    input:
        codon_aln = os.path.join(OUTROOT, "{label}", "{sample}"),
        tree      = rules.AssignLineages.output.output,
        test_list = lambda wc: test_list_path(wc.label)
    output:
        output = os.path.join(OUTROOT, "{label}", "{sample}.RELAX.json")
    params:
        refClade = "Test",
        bgClade = "Background"
    run:
        import os
        # hard gate: if missing or empty, don't run (but also don't crash the whole pipeline)
        if (not os.path.exists(input.test_list)) or os.path.getsize(input.test_list) == 0:
            # create a tiny sentinel? better: raise a clear error if somehow scheduled
            raise ValueError(f"RELAX scheduled but Test list missing/empty: {input.test_list}")
        shell(
            "{HYPHY} RELAX --alignment {input.codon_aln} --tree {input.tree} "
            "--output {output.output} --reference {params.bgClade} --test {params.refClade}"
        )
#end rule


rule CFEL:
    input:
        codon_aln = os.path.join(OUTROOT, "{label}", "{sample}"),
        tree      = rules.AssignLineages.output.output,
        test_list = lambda wc: test_list_path(wc.label)
    output:
        output = os.path.join(OUTROOT, "{label}", "{sample}.CFEL.json")
    params:
        refClade = "Test"
    run:
        import os
        if (not os.path.exists(input.test_list)) or os.path.getsize(input.test_list) == 0:
            raise ValueError(f"CFEL scheduled but Test list missing/empty: {input.test_list}")
        shell(
            "{HYPHY} contrast-fel --alignment {input.codon_aln} --tree {input.tree} "
            "--output {output.output} --branch-set {params.refClade}"
        )
#end rule

