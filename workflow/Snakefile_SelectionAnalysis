                            f"Pass via --config samples_csv=...")

# Load sample sheet
with open(SAMPLES_CSV, "r", newline="") as fh:
    reader = csv.DictReader(fh)
    required_cols = {"sample"}
    missing = required_cols - set(reader.fieldnames or [])
    if missing:
        raise ValueError(f"[SelectionAnalysis] samples.csv missing required columns: {sorted(missing)}. "
                         f"Found: {reader.fieldnames}")
    SAMPLE_ROWS = [row for row in reader]

SAMPLES = [r["sample"] for r in SAMPLE_ROWS]
SAMPLE_ROW = {r["sample"]: r for r in SAMPLE_ROWS}

def outdir(label: str) -> str:
    return os.path.join(OUTROOT, label)

def recombinants(label: str):
    """Segment alignments produced by the main workflow (expected: *.codon.fas)."""
    return sorted([os.path.basename(x) for x in glob.glob(os.path.join(outdir(label), "*.codon.fas"))])

def recombinant_trees(label: str):
    """Trees produced by the main workflow (expected: *.tree.nwk)."""
    return sorted([os.path.basename(x) for x in glob.glob(os.path.join(outdir(label), "*.tree.nwk"))])

def clade_files(label: str):
    """Clade label files produced by the main workflow (expected: *.clade)."""
    return sorted([x for x in glob.glob(os.path.join(outdir(label), "*.clade"))])

def reference_clade(label: str) -> str:
    files = clade_files(label)
    if not files:
        return ""
    return os.path.basename(files[0]).split(".")[0]

def hyphy_branch_arg(wc):
    """
    Return '--branches Test' only if the Test list exists AND is non-empty.
    Otherwise return ''.

    This must be existence-safe because Snakemake may evaluate it during DAG build.
    """
    import os

    test_list = os.path.join(
        OUTROOT,
        wc.label,
        f"{wc.label}.test_sequences.txt"
    )

    if not os.path.exists(test_list):
        return ""

    if os.path.getsize(test_list) == 0:
        return ""

    return "--branches Test"

def test_list_path(label: str) -> str:
    return os.path.join(OUTROOT, label, f"{label}.test_sequences.txt")

def has_test_foreground(label: str) -> bool:
    p = test_list_path(label)
    return os.path.exists(p) and os.path.getsize(p) > 0

#LABELS_WITH_TEST = [l for l in LABELS if has_test_foreground(l)]

# Build concrete targets for rule all (SelectionAnalysis runs after the main workflow,
# so recombinant segments should already exist on disk).
ALL_TARGETS = []
for label in SAMPLES:
    segs = recombinants(label)
    trees = recombinant_trees(label)

    # If no segments exist for this label, skip gracefully.
    if not segs:
        continue

    # Foreground gating: only run foreground-only methods if Test list exists+non-empty
    test_list = os.path.join(outdir(label), f"{label}.test_sequences.txt")
    has_test = os.path.exists(test_list) and os.path.getsize(test_list) > 0

    for seg in segs:
        # Always-run targets
        ALL_TARGETS.extend([
            os.path.join(outdir(label), f"{seg}.FastTree.treefile"),
            os.path.join(outdir(label), f"{seg}.FEL.json"),
            os.path.join(outdir(label), f"{seg}.MEME.json"),
            os.path.join(outdir(label), f"{seg}.ABSREL.json"),
            os.path.join(outdir(label), f"{seg}.BUSTEDS-MH.json"),
        ])

        # Only run RELAX / CFEL if we truly have a Test foreground and a labelled tree
        labelled_tree = os.path.join(outdir(label), f"{seg}.FastTree.treefile.labelled")
        if has_test and os.path.exists(labelled_tree):
            ALL_TARGETS.extend([
                os.path.join(outdir(label), f"{seg}.RELAX.json"),
                os.path.join(outdir(label), f"{seg}.CFEL.json"),
            ])

    # tree labelling targets (if any trees exist)
    for t in trees:
        ALL_TARGETS.append(os.path.join(outdir(label), f"{t}.labelled"))

# -----------------------------------------------------------------------------

rule all:
    input:
        ALL_TARGETS

