def _is_missing(x):
    if x is None:
        return True
    if isinstance(x, float) and math.isnan(x):
        return True
    s = str(x).strip()
    return (s == "") or (s.lower() == "nan")

def codon_fasta_path(sample):
    return os.path.join(BASEDIR, CODON_FASTA_BY_SAMPLE[sample])

def labels_csv_path(sample):
    v = LABELS_CSV_BY_SAMPLE.get(sample, None)
    if _is_missing(v):
        return ""
    return os.path.join(BASEDIR, str(v))

