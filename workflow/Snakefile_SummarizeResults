        analysis_tag = lambda wc: wc.label,
        working_dir  = lambda wc: outdir(wc.label)
    shell:
        r"""
        mkdir -p $(dirname {output.summary})
        python scripts/executive_summary.py \
          --label "{params.analysis_tag}" \
          --out "{output.summary}" \
          --workdir "{params.working_dir}"
        """
