        fel_jsons   = lambda wc: sorted(glob.glob(os.path.join(outdir(wc.label), "*.FEL.json"))),
        meme_jsons  = lambda wc: sorted(glob.glob(os.path.join(outdir(wc.label), "*.MEME.json"))),
