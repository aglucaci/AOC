# -----------------------------------------------------------------------------
# Label tree with clade labels (per gene, per part)
# -----------------------------------------------------------------------------
rule AssignLineages:
    input:
        tree=rules.fasttree.output.tree,
        clades_done=rules.build_clades.output.sentinel
    output:
        output="results/{gene}/{gene}.{part}.codon.fas.FastTree.treefile.labelled"
    log:
        os.path.join(LOG_DIR, "{gene}.{part}.label_tree.log")
    run:
        import os as _os

        outdir = _os.path.dirname(output.output)
        clade_files = sorted(glob.glob(_os.path.join(outdir, "*.clade")))
        if not clade_files:
            raise ValueError(f"No .clade files found in {outdir}. build_clades should have created them.")

        first_time = True
        for clade_file in clade_files:
            label = _os.path.basename(clade_file).split(".")[0]

            if first_time:
                cmd = " ".join([HYPHY, LABEL_TREE_BF,
                                "--tree", input.tree,
                                "--list", clade_file,
                                "--output", output.output,
                                "--label", label])
                first_time = False
            else:
                cmd = " ".join([HYPHY, LABEL_TREE_BF,
                                "--tree", output.output,
                                "--list", clade_file,
                                "--output", output.output,
                                "--label", label])

            os.system(cmd)

        #with open(log, "w") as fh:
        #    fh.write("label-tree completed\n")

