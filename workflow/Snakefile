# Base and data paths
BASEDIR = os.getcwd()

# NCBI email (optional but recommended for Entrez)
Email = config.get("Email", "")

# Samples sheet (drives per-sample inputs)
# - runner passes: --config samples_csv=path/to/samples.csv
# - fallback: ./samples.csv
SAMPLE_SHEET = config.get("samples_csv", os.path.join(BASEDIR, "samples.csv"))
samples_df = pd.read_csv(SAMPLE_SHEET)

REQUIRED_COLS = {"sample", "codon_fasta", "sequence_labels_csv"}
missing = REQUIRED_COLS.difference(samples_df.columns)
if missing:
    raise ValueError(f"[ERROR] samples sheet missing required column(s) {sorted(missing)}: {SAMPLE_SHEET}")

samples_df["sample"] = samples_df["sample"].astype(str)

# List of samples (each row defines one independent run)
SAMPLES = samples_df["sample"].tolist()

# Lookup tables for per-sample inputs
CODON_FASTA_BY_SAMPLE = dict(zip(samples_df["sample"], samples_df["codon_fasta"].astype(str)))
LABELS_CSV_BY_SAMPLE  = dict(zip(samples_df["sample"], samples_df["sequence_labels_csv"].astype(str)))

# Output directories
OUTDIR_RESULTS = os.path.join(BASEDIR, "results")
os.makedirs(OUTDIR_RESULTS, exist_ok=True)

def outdir(sample: str) -> str:
    d = os.path.join(OUTDIR_RESULTS, sample)
    os.makedirs(d, exist_ok=True)
    return d

def codon_fasta_path(sample: str) -> str:
    return os.path.join(BASEDIR, CODON_FASTA_BY_SAMPLE[sample])

def _is_missing_path(x) -> bool:
    # catches: None, "", "nan", numpy.nan, float('nan')
    if x is None:
        return True
    if isinstance(x, float) and math.isnan(x):
        return True
    s = str(x).strip()
    return (s == "") or (s.lower() == "nan")

def labels_csv_path(sample: str) -> str:
    v = LABELS_CSV_BY_SAMPLE.get(sample, None)
    if _is_missing_path(v):
        return ""  # signals "no labels csv"
    return os.path.join(BASEDIR, str(v))

# Only run header-map/Test-list generation for samples whose sequence_labels_csv exists
SAMPLES_WITH_LABELS = [
    s for s in SAMPLES
    if (not _is_missing_path(LABELS_CSV_BY_SAMPLE.get(s, None)))
    and os.path.exists(labels_csv_path(s))
]

