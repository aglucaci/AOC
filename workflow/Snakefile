          > {log} 2>&1
        """

# -----------------------------------------------------------------------------
# 11) Build clade label files from the lineages TSV
#     Produces:
#       - results/{gene}/reference_clade.txt
#       - results/{gene}/<CladeName>.clade (at least 2 clades)
#
# This is the glue needed to run RELAX / CFEL / labelled trees in the SelectionAnalysis Snakefile.
# -----------------------------------------------------------------------------
rule build_clades:
    input:
        lineages="results/{gene}/{gene}.lineages.tsv"
    output:
        ref="results/{gene}/reference_clade.txt",
        sentinel="results/{gene}/.clades.done"
    log:
        os.path.join(LOG_DIR, "{gene}.clades.log")
    run:
        import pandas as _pd
        import os as _os

        df = _pd.read_csv(input.lineages, sep="\t")

        # Accept either schema:
        # - old: LEAFNAME, LINEAGE
        # - new: leaf, lineage
        col_leaf = "LEAFNAME" if "LEAFNAME" in df.columns else ("leaf" if "leaf" in df.columns else None)
        col_lin  = "LINEAGE"  if "LINEAGE"  in df.columns else ("lineage" if "lineage" in df.columns else None)
        if not col_leaf or not col_lin:
            raise ValueError(
                f"Expected (LEAFNAME, LINEAGE) or (leaf, lineage) columns in {input.lineages}. Found: {list(df.columns)}"
            )

        # LINEAGE is semicolon-joined; split to lists
        lineage_lists = []
        for v in df[col_lin].fillna("Unknown").astype(str).tolist():
            lineage_lists.append([x.strip() for x in v.split(";") if x.strip()] if v != "Unknown" else ["Unknown"])
        df["_LINEAGE_LIST"] = lineage_lists

        # Find best depth with >=2 clades and >=N members each (configurable)
        min_members = int(config.get("clade_min_members", 3))
        min_clades  = int(config.get("clade_min_clades", 2))

        max_depth = max((len(x) for x in lineage_lists if isinstance(x, list)), default=0)
        best_depth = None
        best_lineages = None

        for depth in range(max_depth):
            col = [x[depth] if isinstance(x, list) and len(x) > depth else "Unknown" for x in df["_LINEAGE_LIST"]]
            counts = _pd.Series(col).value_counts()
            valid = counts[counts >= min_members]
            if len(valid) >= min_clades:
                best_depth = depth
                best_lineages = list(valid.index)
                break

        if not best_lineages:
            # Fallback: take top-2 labels at depth 0 (often broad taxa)
            col0 = [x[0] if isinstance(x, list) and len(x) else "Unknown" for x in df["_LINEAGE_LIST"]]
            counts0 = _pd.Series(col0).value_counts()
            best_lineages = [x for x in counts0.index if x != "Unknown"][:2]
            best_depth = 0

        if not best_lineages or len(best_lineages) < 2:
            raise ValueError(
                f"Could not derive >=2 clades from {input.lineages}. "
                f"Try lowering clade_min_members in config.yml."
            )

        # Deterministic clade order
        best_lineages_sorted = sorted(best_lineages)

        # Pick reference clade: config override, else first (sorted)
        ref_clade = config.get("reference_clade", best_lineages_sorted[0])

        outdir = _os.path.dirname(output.ref)
        _os.makedirs(outdir, exist_ok=True)

        # IMPORTANT: prevent appending across reruns by truncating each clade file first
        for label in best_lineages_sorted:
            clade_path = _os.path.join(outdir, f"{label}.clade")
            open(clade_path, "w").close()

        # Write .clade files
        written = set()
        for _, row in df.iterrows():
            leaf = str(row[col_leaf])
            lin = row["_LINEAGE_LIST"]
            label = "Unknown"
            if isinstance(lin, list) and best_depth is not None and len(lin) > best_depth:
                candidate = lin[best_depth]
                if candidate in best_lineages_sorted:
                    label = candidate

            if label != "Unknown":
                clade_path = _os.path.join(outdir, f"{label}.clade")
                with open(clade_path, "a") as fh:
                    fh.write(f"{leaf}\n")
                written.add(label)

        if len(written) < 2:
            raise ValueError(f"Only {len(written)} clade file(s) written for {wildcards.gene}. Need >=2.")

        with open(output.ref, "w") as fh:
            fh.write(str(ref_clade).strip() + "\n")

        with open(output.sentinel, "w") as fh:
            fh.write("ok\n")

        # Log info
        #os.makedirs(_os.path.dirname(log), exist_ok=True)
        #with open(log, "w") as fh:
        #    fh.write(f"best_depth={best_depth}\n")
        #    fh.write(f"clades={best_lineages_sorted}\n")
        #    fh.write(f"reference_clade={ref_clade}\n")
        #    fh.write(f"min_members={min_members}\n")
        #    fh.write(f"min_clades={min_clades}\n")


# =============================================================================
# Selection Analysis (merged from Snakefile_SelectionAnalysis)
# =============================================================================


# -----------------------------------------------------------------------------
# Aggregate: run ALL selection analyses for ALL parts (per gene)
# Produces: results/{gene}/.selection.done
# -----------------------------------------------------------------------------
def selection_outputs_for_gene(wc):
    g = wc.gene
    parts = parts_for_gene(g)
    outs = []
    # Core per-part selection outputs
    patterns = [
        "results/{gene}/{gene}.{part}.codon.fas.dst",
        "results/{gene}/{gene}.{part}.codon.fas.FastTree.treefile",
        "results/{gene}/{gene}.{part}.codon.fas.FEL.json",
        "results/{gene}/{gene}.{part}.codon.fas.FUBAR.json",
        "results/{gene}/{gene}.{part}.codon.fas.BUSTEDS.json",
        "results/{gene}/{gene}.{part}.codon.fas.MEME.json",
        "results/{gene}/{gene}.{part}.codon.fas.ABSREL.json",
        "results/{gene}/{gene}.{part}.codon.fas.SLAC.json",
        "results/{gene}/{gene}.{part}.codon.fas.RELAX.json",
        "results/{gene}/{gene}.{part}.codon.fas.CFEL.json",
    ]
    for pat in patterns:
        outs.extend(expand(pat, gene=g, part=parts))
    return outs

rule selection_all_parts:
    input:
        selection_outputs_for_gene,
        # clades needed for labelled-tree methods
        rules.build_clades.output.sentinel
    output:
        "results/{gene}/.selection.done"
    shell:
        "echo ok > {output}"

