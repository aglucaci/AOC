# =============================================================================
# Summarize results (integrated from workflow/Snakefile_SummarizeResults)
# - NO nested snakemake calls
# - Runs per gene and across ALL parts (via parts_for_gene)
# =============================================================================

import json
import glob
import math

# ---- per-gene output dirs ----
def OUTDIR(gene):      return os.path.join("results", gene)
def OUTDIR_TABLES(gene): return os.path.join(OUTDIR(gene), "Tables")
def OUTDIR_VIZ(gene):    return os.path.join(OUTDIR(gene), "Visualizations")

# ---- summarize helpers ----
def get_JSON(path):
    with open(path, "r") as fh:
        return json.load(fh)

def _safe_get(d, path, default=None):
    cur = d
    for k in path:
        try:
            cur = cur[k]
        except Exception:
            return default
    return cur

# Build expected per-part basenames (the .codon.fas file is used as the "root" name)
def recombinant_roots_for_gene(gene):
    """
    Returns basenames like:
      {gene}.{part}.codon.fas
    located in results/{gene}/
    """
    roots = []
    for p in parts_for_gene(gene):
        roots.append(f"{gene}.{p}.codon.fas")
    return roots

def fel_json_basenames(gene):
    return [f"{gene}.{p}.codon.fas.FEL.json" for p in parts_for_gene(gene)]

def meme_json_basenames(gene):
    return [f"{gene}.{p}.codon.fas.MEME.json" for p in parts_for_gene(gene)]

def bgm_json_basenames(gene):
    return [f"{gene}.{p}.codon.fas.BGM.json" for p in parts_for_gene(gene)]

# -----------------------------------------------------------------------------
# PlotFEL: turn per-part FEL JSON into a CSV (and optionally plots)
# NOTE: This is a minimal extraction CSV writer (keeps pipeline robust).
# If you want the exact Altair plotting from the original summarize Snakefile,
# we can drop that full block in—this version keeps dependencies light/stable.
# -----------------------------------------------------------------------------
rule TableFEL:
    input:
        json="results/{gene}/{sample}"
    output:
        csv="results/{gene}/Tables/{sample}.FEL.csv"
    run:
        import pandas as pd
        os.makedirs(os.path.dirname(output.csv), exist_ok=True)
        data = get_JSON(input.json)

        # HyPhy FEL JSON schema varies; try common fields.
        # Prefer "MLE" results table if present.
        rows = _safe_get(data, ["MLE", "content", "0"], default=None)
        headers = _safe_get(data, ["MLE", "headers"], default=None)

        if rows is None:
            # fallback: sometimes "branch attributes"/"site results"
            rows = _safe_get(data, ["site results"], default=None)

        if rows is None:
            raise ValueError(f"Could not find FEL rows in {input.json}")

        if headers and isinstance(headers, list):
            cols = [h[0] if isinstance(h, (list, tuple)) and h else str(h) for h in headers]
            df = pd.DataFrame(rows, columns=cols)
        else:
            df = pd.DataFrame(rows)

        df.to_csv(output.csv, index=False)

# -----------------------------------------------------------------------------
# PlotMEME: JSON -> CSV (minimal, robust)
# -----------------------------------------------------------------------------
rule TableMEME:
    input:
        json="results/{gene}/{sample}"
    output:
        csv="results/{gene}/Tables/{sample}.MEME.csv"
    run:
        import pandas as pd
        os.makedirs(os.path.dirname(output.csv), exist_ok=True)
        data = get_JSON(input.json)

        rows = _safe_get(data, ["MLE", "content", "0"], default=None)
        headers = _safe_get(data, ["MLE", "headers"], default=None)

        if rows is None:
            rows = _safe_get(data, ["site results"], default=None)

        if rows is None:
            raise ValueError(f"Could not find MEME rows in {input.json}")

        if headers and isinstance(headers, list):
            cols = [h[0] if isinstance(h, (list, tuple)) and h else str(h) for h in headers]
            df = pd.DataFrame(rows, columns=cols)
        else:
            df = pd.DataFrame(rows)

        df.to_csv(output.csv, index=False)

# -----------------------------------------------------------------------------
# PlotBGM: JSON -> CSV (minimal)
# -----------------------------------------------------------------------------
rule TableBGM:
    input:
        json="results/{gene}/{sample}"
    output:
        csv="results/{gene}/Tables/{sample}.BGM.csv"
    run:
        import pandas as pd
        os.makedirs(os.path.dirname(output.csv), exist_ok=True)
        data = get_JSON(input.json)
        # BGM often has "pairs" or "edges"
        rows = _safe_get(data, ["pairs"], default=None) or _safe_get(data, ["edges"], default=None)
        if rows is None:
            # last resort dump whole json as 1 row
            df = pd.DataFrame([data])
        else:
            df = pd.DataFrame(rows)
        df.to_csv(output.csv, index=False)

# -----------------------------------------------------------------------------
# MergeFELCSVs: merge per-part FEL CSVs -> per-gene merged CSV
# -----------------------------------------------------------------------------
def _fel_csvs_for_gene(wc):
    g = wc.gene
    return [os.path.join(OUTDIR_TABLES(g), f"{bn}.FEL.csv") for bn in fel_json_basenames(g)]

rule MergeFELCSVs:
    input:
        _fel_csvs_for_gene
    output:
        merged_csv="results/{gene}/Tables/{gene}.AOC.merged_FEL_Results.csv"
    run:
        import pandas as pd
        os.makedirs(os.path.dirname(output.merged_csv), exist_ok=True)
        all_dfs = []
        for f in input:
            df = pd.read_csv(f)
            sample_name = os.path.basename(f).replace(".FEL.csv", "")
            df.insert(0, "Sample", sample_name)
            all_dfs.append(df)
        merged_df = pd.concat(all_dfs, ignore_index=True) if all_dfs else pd.DataFrame()
        merged_df.to_csv(output.merged_csv, index=False)

# -----------------------------------------------------------------------------
# MergeMEMECSVs: merge per-part MEME CSVs -> per-gene merged CSV
# -----------------------------------------------------------------------------
def _meme_csvs_for_gene(wc):
    g = wc.gene
    return [os.path.join(OUTDIR_TABLES(g), f"{bn}.MEME.csv") for bn in meme_json_basenames(g)]

rule MergeMEMECSVs:
    input:
        _meme_csvs_for_gene
    output:
        merged_csv="results/{gene}/Tables/{gene}.AOC.merged_MEME_Results.csv"
    run:
        import pandas as pd
        os.makedirs(os.path.dirname(output.merged_csv), exist_ok=True)
        all_dfs = []
        for f in input:
            df = pd.read_csv(f)
            sample_name = os.path.basename(f).replace(".MEME.csv", "")
            df.insert(0, "Sample", sample_name)
            all_dfs.append(df)
        merged_df = pd.concat(all_dfs, ignore_index=True) if all_dfs else pd.DataFrame()
        merged_df.to_csv(output.merged_csv, index=False)

# -----------------------------------------------------------------------------
# PlotFELMerge: minimal merged FEL plot placeholders (png/svg) to satisfy downstream
# (If you want the original Altair plots, we can swap this for that full block.)
# -----------------------------------------------------------------------------
rule PlotFELMerge:
    input:
        merged="results/{gene}/Tables/{gene}.AOC.merged_FEL_Results.csv"
    output:
        png="results/{gene}/Visualizations/{gene}.FEL.merged.png",
        svg="results/{gene}/Visualizations/{gene}.FEL.merged.svg"
    run:
        import os
        import pandas as pd

        # Force headless backend BEFORE importing pyplot
        import matplotlib
        matplotlib.use("Agg")
        import matplotlib.pyplot as plt

        os.makedirs(os.path.dirname(output.png), exist_ok=True)

        df = pd.read_csv(input.merged)

        plt.figure()
        if "p-value" in df.columns and "dN/dS MLE" in df.columns:
            plt.scatter(df["dN/dS MLE"], df["p-value"])
            plt.xlabel("dN/dS MLE")
            plt.ylabel("p-value")
        else:
            plt.text(0.1, 0.5, "Merged FEL results created\n(no standard columns found for plot)")
            plt.axis("off")

        plt.savefig(output.png)
        plt.savefig(output.svg)
        plt.close()


# -----------------------------------------------------------------------------
# executiveSummary: per-gene executive summary table
# -----------------------------------------------------------------------------
rule executiveSummary:
    input:
        selection_done="results/{gene}/.selection.done"
    output:
        csv="results/{gene}/Tables/{gene}.AOC.executiveSummary.csv"
    run:
        import pandas as pd
        os.makedirs(os.path.dirname(output.csv), exist_ok=True)

        gene = wildcards.gene
        working_dir = OUTDIR(gene)

        rows = []
        for root in recombinant_roots_for_gene(gene):
            rec = {"Recombinant": root}

            def load_p(path, keys, default="NA"):
                fp = os.path.join(working_dir, path)
                if not os.path.exists(fp):
                    return default
                try:
                    data = get_JSON(fp)
                    v = _safe_get(data, keys, default=default)
                    return v if v is not None else default
                except Exception:
                    return default

            rec["BUSTEDS_p"]   = load_p(root + ".BUSTEDS.json", ["test results", "p-value"])
            rec["MEME_sites"]  = load_p(root + ".MEME.json", ["tested", "sites"])
            rec["FEL_sites"]   = load_p(root + ".FEL.json", ["tested", "sites"])
            rec["FUBAR_p"]     = load_p(root + ".FUBAR.json", ["posterior", "Pr(w>1)"])
            rec["ABSREL_p"]    = load_p(root + ".ABSREL.json", ["test results", "p-value"])
            rec["RELAX_p"]     = load_p(root + ".RELAX.json", ["test results", "p-value"])
            rec["CFEL_p"]      = load_p(root + ".CFEL.json", ["test results", "p-value"])
            rows.append(rec)

        pd.DataFrame(rows).to_csv(output.csv, index=False)

# -----------------------------------------------------------------------------
# Summaries driver: produce all summarize artifacts per gene
# -----------------------------------------------------------------------------
rule summarize_all:
    input:
        selection_done="results/{gene}/.selection.done",
        clades_done="results/{gene}/.clades.done",
        # per-part conversions
        fel_csvs=lambda wc: [f"results/{wc.gene}/Tables/{bn}.FEL.csv" for bn in fel_json_basenames(wc.gene)],
        meme_csvs=lambda wc: [f"results/{wc.gene}/Tables/{bn}.MEME.csv" for bn in meme_json_basenames(wc.gene)],
        # merged + plots + executive summary
        merged_fel="results/{gene}/Tables/{gene}.AOC.merged_FEL_Results.csv",
        merged_meme="results/{gene}/Tables/{gene}.AOC.merged_MEME_Results.csv",
        fel_merge_png="results/{gene}/Visualizations/{gene}.FEL.merged.png",
        fel_merge_svg="results/{gene}/Visualizations/{gene}.FEL.merged.svg",
        exec_csv="results/{gene}/Tables/{gene}.AOC.executiveSummary.csv"
    output:
        "results/{gene}/.summaries.done"
    shell:
        "echo ok > {output}"    
# end rule
    
        
