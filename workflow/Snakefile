        RefClade=lambda wc, input: open(input.ref).read().strip()
    shell:
        r"""
        {HYPHY} RELAX --alignment {input.aln} --tree {input.tree} --output {output.output} \
          --reference-group {params.RefClade} --models All --mode 'Group mode' --starting-points 25 --srv Yes \
          > {log} 2>&1
        """

