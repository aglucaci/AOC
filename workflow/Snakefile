if not MANIFEST:
    raise ValueError(
        "config.yml must define MANIFEST pointing to a CSV with columns: "
        "gene,cds_file,protein_file,orthologs_file"
    )

manifest_df = pd.read_csv(MANIFEST)
required_cols = {"gene", "cds_file", "protein_file", "orthologs_file"}
missing = required_cols - set(manifest_df.columns)
if missing:
    raise ValueError(f"Manifest is missing required columns: {sorted(missing)}. Found: {list(manifest_df.columns)}")

GENES = manifest_df["gene"].dropna().astype(str).unique().tolist()
if not GENES:
    raise ValueError("No genes found in MANIFEST (column 'gene').")

# Constrain wildcards so typos fail fast
wildcard_constraints:
    gene="(" + "|".join(map(lambda s: s.replace("(", r"\(").replace(")", r"\)"), GENES)) + ")",
    part=r"\d+"

# -----------------------------------------------------------------------------
# Helper path/lookup functions
# -----------------------------------------------------------------------------
def _row_for_gene(gene: str):
    rows = manifest_df.loc[manifest_df["gene"].astype(str) == str(gene)]
    if rows.shape[0] != 1:
        raise ValueError(f"Expected exactly one row for gene={gene}, found {rows.shape[0]}")
    return rows.iloc[0]

def cds_for_gene(wc):
    return str(_row_for_gene(wc.gene)["cds_file"])

def protein_for_gene(wc):
    return str(_row_for_gene(wc.gene)["protein_file"])

def orthologs_for_gene(wc):
    return str(_row_for_gene(wc.gene)["orthologs_file"])

def outdir_for_gene(wc):
    return os.path.join("results", wc.gene)

