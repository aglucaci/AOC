def save_altair_with_vl_convert(chart, *, png_path=None, svg_path=None, scale=2, ppi=None):
    try:
        import vl_convert as vlc
    except ImportError as e:
        raise ImportError(
            "vl-convert-python is not installed. Install with: pip install vl-convert-python or conda install -c conda-forge vl-convert-python"
        ) from e

    spec = chart.to_dict(format="vega-lite")
    for out in (png_path, svg_path):
        if out:
            Path(out).parent.mkdir(parents=True, exist_ok=True)

    if svg_path:
        svg = vlc.vegalite_to_svg(spec)
        with open(svg_path, "w", encoding="utf-8") as f:
            f.write(svg)

    if png_path:
        kwargs = {"scale": scale}
        if ppi is not None:
            kwargs["ppi"] = ppi
        png = vlc.vegalite_to_png(spec, **kwargs)
        with open(png_path, "wb") as f:
            f.write(png)


def _safe_fdrcorrection(pvals, alpha=0.10):
    vals = [float(x) for x in pvals]
    if len(vals) == 0:
        return []
    return fdrcorrection(vals, alpha=alpha, method="indep", is_sorted=False)[1]


def _read_json(path):
    with open(path, "r") as fh:
        return json.load(fh)


def _hyphy_headers(data):
    return [x[0] for x in data["MLE"]["headers"]]


def _hyphy_content_table(data):
    return data["MLE"]["content"]["0"]


def _ensure_empty_test_list(sample):
    path = empty_test_list_file(sample)
    if not os.path.exists(path):
        os.makedirs(os.path.dirname(path), exist_ok=True)
        with open(path, "w") as fh:
            fh.write("")
    return path


def _test_list_for_sample(wc):
    path = test_list_file(wc.sample)
    if os.path.exists(path):
        return path
    return _ensure_empty_test_list(wc.sample)


def _branch_arg(sample):
    path = test_list_file(sample)
    if os.path.exists(path) and os.path.getsize(path) > 0:
        return "--branches Test"
    return ""


