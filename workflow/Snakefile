# If your custom gard_parser exists (e.g. defined below or imported), it will be used.
# Otherwise, we copy the full MSA as partition 1 so downstream doesn't crash.
def _fallback_gard_parser(bestgard_path, msa_path, out_fas_path, log_path):
    with open(msa_path, "r") as fin, open(out_fas_path, "w") as fout:
        fout.write(fin.read())
    with open(log_path, "w") as flog:
        flog.write(f"Fallback parser used; copied {msa_path} -> {out_fas_path}\n")

