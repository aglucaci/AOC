# -----------------------------------------------------------------------------
# 1) Extract codons per gene (uses your existing scripts/codons.py which expects `snakemake`)
# -----------------------------------------------------------------------------
rule get_codons:
    input:
        nuc=cds_for_gene,
        prot=protein_for_gene
    output:
        codons="results/{gene}/{gene}.codons.fa",
        map="results/{gene}/{gene}.codons.fa.map.tsv"
    params:
        Prot=protein_for_gene,
        Nuc=cds_for_gene,
        Out="results/{gene}/{gene}.codons.fa"
    log:
        os.path.join(LOG_DIR, "{gene}.codons.log")
    script:
        os.path.join(BASEDIR, "scripts", "codons.py")

# -----------------------------------------------------------------------------
# 2) Align sequences with MACSE
# -----------------------------------------------------------------------------
rule macse:
    input:
        codons=rules.get_codons.output.codons
    output:
        codons="results/{gene}/{gene}.codons.raw.fa",
        aa="results/{gene}/{gene}.aa.fa"
    params:
        MACSE_CMD=config.get("MACSE_CMD", "macse"),
    log:
        os.path.join(LOG_DIR, "{gene}.macse.log")
    shell:        
        r"""
        mkdir -p results/{wildcards.gene}
        {params.MACSE_CMD} -prog alignSequences \
          -seq {input.codons} \
          -local_realign_init 1 \
          -local_realign_dec 1 \
          -out_NT {output.codons}.tmp \
          -out_AA {output.aa} && \
        sed 's/!/N/g' {output.codons}.tmp > {output.codons} && \
        rm {output.codons}.tmp
        """

# -----------------------------------------------------------------------------
# 3) Clean alignment (HyPhy CLN)
# -----------------------------------------------------------------------------
rule cln:
    input:
        msa=rules.macse.output.codons
    output:
        out="results/{gene}/{gene}.codons.cln.fa"
    log:
        os.path.join(LOG_DIR, "{gene}.cln.log")
    shell:
        r"""
        mkdir -p results/{wildcards.gene}
        {HYPHY} CLN Universal {input.msa} 'No/No' {output.out} > {log} 2>&1
        """

# -----------------------------------------------------------------------------
# 4) Strike ambiguous sequences
# -----------------------------------------------------------------------------
rule strike_ambigs_msa:
    input:
        msa=rules.cln.output.out
    output:
        out="results/{gene}/{gene}.SA.codons.cln.fa"
    log:
        os.path.join(LOG_DIR, "{gene}.strike_ambigs.log")
    shell:
        r"""
        {HYPHY} {STRIKE_AMBIGS_BF} --alignment {input.msa} --output {output.out} > {log} 2>&1
        """

# -----------------------------------------------------------------------------
# 5) Remove duplicates
# -----------------------------------------------------------------------------
rule remove_duplicates_msa:
    input:
        msa=rules.strike_ambigs_msa.output.out
    output:
        out="results/{gene}/{gene}.RD.SA.codons.cln.fa"
    log:
        os.path.join(LOG_DIR, "{gene}.remove_dups.log")
    shell:
        r"""
        {HYPHY} {REMOVE_DUPS_BF} --msa {input.msa} --output {output.out} ENV='DATA_FILE_PRINT_FORMAT=9' > {log} 2>&1
        """

# -----------------------------------------------------------------------------
# 6) IQ-TREE
# -----------------------------------------------------------------------------
rule iqtree:
    input:
        msa=rules.remove_duplicates_msa.output.out
    output:
        tree="results/{gene}/{gene}.RD.SA.codons.cln.fa.treefile"
    log:
        os.path.join(LOG_DIR, "{gene}.iqtree.log")
    shell:
        r"""
        iqtree -s {input.msa} -T AUTO -B 1000 --redo-tree > {log} 2>&1
        """

# -----------------------------------------------------------------------------
# 7) TN93 clustering (your custom script)
# -----------------------------------------------------------------------------
rule tn93_cluster:
    params:
        threshold=float(config.get("tn93_threshold", 0.01)),
        max_seqs=int(config.get("tn93_max_seqs", 20))
    input:
        msa=rules.remove_duplicates_msa.output.out
    output:
        output_json="results/{gene}/{gene}.RD.SA.codons.cln.fa.cluster.json",
        output_fasta="results/{gene}/{gene}.RD.SA.codons.cln.fa.cluster.fasta"
    log:
        os.path.join(LOG_DIR, "{gene}.tn93_cluster.log")
    shell:
        r"""
        python3 {TN93_CLUSTER_SCRIPT} \
          --input {input.msa} \
          --output_fasta {output.output_fasta} \
          --output_json {output.output_json} \
          --threshold {params.threshold} \
          --max_retain {params.max_seqs} \
          > {log} 2>&1
        """

# -----------------------------------------------------------------------------
# 8) Recombination (GARD)
# -----------------------------------------------------------------------------
rule recombination:
    input:
        msa=rules.tn93_cluster.output.output_fasta
    output:
        json="results/{gene}/{gene}.RD.SA.codons.cln.fa.cluster.fasta.GARD.json",
        bestgard="results/{gene}/{gene}.RD.SA.codons.cln.fa.cluster.fasta.best-gard"
    log:
        os.path.join(LOG_DIR, "{gene}.gard.log")
    params:
        mode=config.get("gard_mode", "Faster"),
        use_mpi=bool(config.get("gard_use_mpi", False)),
    shell:
        r"""
        mkdir -p results/{wildcards.gene}
        if [ "{params.use_mpi}" = "True" ]; then
          mpirun --use-hwthread-cpus {HYPHYMPI} GARD --alignment {input.msa} --output {output.json} --mode {params.mode} \
            ENV=TOLERATE_NUMERICAL_ERRORS=1 > {log} 2>&1
        else
          {HYPHY} GARD --alignment {input.msa} --output {output.json} --mode {params.mode} \
            ENV=TOLERATE_NUMERICAL_ERRORS=1 > {log} 2>&1
        fi
        # HyPhy typically writes *.best-gard next to output; if not, keep the output target satisfied
        if [ -f "{output.bestgard}" ]; then
          true
        elif ls results/{wildcards.gene}/*.best-gard 1>/dev/null 2>&1; then
          cp results/{wildcards.gene}/*.best-gard "{output.bestgard}"
        else
          touch "{output.bestgard}"
        fi
        """

# -----------------------------------------------------------------------------
# 9) Parse GARD partitions (part=1 by default)
# -----------------------------------------------------------------------------
"""
rule parse_gard:
    input:
        gard_json="results/{gene}/{gene}.RD.SA.codons.cln.fa.cluster.fasta.GARD.json",
        msa="results/{gene}/{gene}.RD.SA.codons.cln.fa.cluster.fasta"
    output:
        codon_fas="results/{gene}/{gene}.{part}.codon.fas"
    log:
        os.path.join(LOG_DIR, "{gene}.{part}.parse_gard.log")
    run:
        # Prefer your original gard_parser if you have it defined/imported
        if "gard_parser" in globals() and callable(globals()["gard_parser"]):
            globals()["gard_parser"](wildcards.gene, input.bestgard, input.msa)
            if not os.path.exists(output.codon_partition):
                _fallback_gard_parser(input.bestgard, input.msa, output.codon_partition, output.log)
        else:
            _fallback_gard_parser(input.bestgard, input.msa, output.codon_partition, output.log)
"""

# -----------------------------------------------------------------------------
# GARD parsing: ALL partitions (checkpoint) using your carryover logic
# -----------------------------------------------------------------------------
checkpoint parse_gard:
    input:
        bestgard=rules.recombination.output.bestgard,
        msa=rules.remove_duplicates_msa.output.out
    output:
        parts_dir=directory("results/{gene}/gard_parts"),
        parts_txt="results/{gene}/gard_parts/parts.txt",
        #"results/{gene}/{gene}.gard.log"
        log="results/{gene}/{gene}.gard.log"
        #os.path.join(LOG_DIR, "{gene}.parse_gard.log")
    run:
        import os
        from Bio import SeqIO

        best_gard_path = input.bestgard
        codon_msa_input = input.msa

        out_dir = output.parts_dir
        os.makedirs(out_dir, exist_ok=True)
        os.makedirs(os.path.join("results", wildcards.gene), exist_ok=True)

        if not os.path.exists(best_gard_path):
            raise FileNotFoundError(f"GARD results file does not exist: {best_gard_path}")

        data = [line.strip() for line in open(best_gard_path) if "CHARSET" in line]
        if not data:
            raise ValueError(
                "GARD best-gard file has no CHARSET spans. "
                "Ensure your .best-gard is the NEXUS-like file containing CHARSET lines."
            )

        # Parse spans like: CHARSET span_1 = 1-262;
        data_parsed = [[int(x) for x in line.split('=')[1].strip(' ;').split('-')] for line in data]
        data_adjusted = [[start - 1, end] for start, end in data_parsed]

        records = list(SeqIO.parse(codon_msa_input, "fasta"))
        if not records:
            raise ValueError(f"No FASTA records found in {codon_msa_input}")

        first_seq = str(records[0].seq)

        # CarryOver codon-boundary enforcement across consecutive partitions
        data_adjusted_coords = []
        carryOver = 0
        for start, end in data_adjusted:
            start2 = start - carryOver
            seg_len = len(first_seq[int(start2): int(end)])
            remainder = seg_len % 3
            data_adjusted_coords.append([start2, end - remainder])
            carryOver = remainder

        written = []
        with open(output.log, "w") as log_file:
            for i, (start, stop) in enumerate(data_adjusted_coords, start=1):
                part_name = f"{wildcards.gene}.{i}.codon.fas"
                out_path = os.path.join(out_dir, part_name)
                with open(out_path, "w") as out_f:
                    for record in records:
                        part = record[int(start):int(stop)]
                        out_f.write(f">{record.id}\n{part.seq}\n")
                written.append(out_path)

                adjusted_len = len(records[0][int(start):int(stop)].seq)
                log_file.write(
                    f"Partition {i}: start={start}, stop={stop}, length={adjusted_len}, remainder={adjusted_len % 3}\n"
                )

                # Compatibility: also copy into results/{gene}/{gene}.{i}.codon.fas
                compat_path = os.path.join("results", wildcards.gene, f"{wildcards.gene}.{i}.codon.fas")
                with open(compat_path, "w") as out_f:
                    for record in records:
                        part = record[int(start):int(stop)]
                        out_f.write(f">{record.id}\n{part.seq}\n")

        with open(output.parts_txt, "w") as fh:
            for p in written:
                fh.write(p + "\n")


# -----------------------------------------------------------------------------
# Dynamic PARTS discovery from the GARD checkpoint
# -----------------------------------------------------------------------------
import os as _os
import re as _re

_PART_INDEX_RE = _re.compile(r"\.(\d+)\.codon\.fas$")

def parts_for_gene(gene):
    """Return a list of partition indices (as strings) for a given gene.

    parse_gard writes parts.txt containing full paths like:
      results/<gene>/gard_parts/<gene>.<i>.codon.fas
    We extract <i> robustly.
    """
    ckpt = checkpoints.parse_gard.get(gene=gene)
    parts_txt = ckpt.output.parts_txt
    parts = []
    with open(parts_txt) as fh:
        for ln in fh:
            p = ln.strip()
            if not p:
                continue
            base = _os.path.basename(p)
            m = _PART_INDEX_RE.search(base)
            if m:
                parts.append(m.group(1))
            else:
                # If parts.txt contains only indices, accept them
                if p.isdigit():
                    parts.append(p)
    # De-dup preserving order
    seen=set()
    parts=[x for x in parts if not (x in seen or seen.add(x))]
    if not parts:
        raise ValueError(f"No partitions discovered for {gene}. parts.txt={parts_txt}")
    return parts

def expand_parts(pattern, gene):
    """Helper to expand a {part}-pattern over dynamic parts for a single gene."""
    return expand(pattern, gene=gene, part=parts_for_gene(gene))

