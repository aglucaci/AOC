MACSE_HEAP_RESERVE_MB = int(config.get("macse_heap_reserve_mb", 1024))
MACSE_MIN_HEAP_MB = int(config.get("macse_min_heap_mb", 2048))
MACSE_XMS_MB = int(config.get("macse_xms_mb", 512))
MACSE_RUNNER = config.get("macse_runner", "scripts/run_macse_with_heap.sh")


def _coerce_int(value):
    try:
        return int(str(value).strip())
    except (TypeError, ValueError, AttributeError):
        return None


def _is_missing(x):
    if x is None:
        return True
    if isinstance(x, float) and math.isnan(x):
        return True
    s = str(x).strip()
    return (s == "") or (s.lower() == "nan")


def _coerce_bool(value, default=False):
    if _is_missing(value):
        return default
    if isinstance(value, bool):
        return value
    return str(value).strip().lower() in {"1", "true", "t", "yes", "y", "on"}


def _recombination_enabled(sample):
    return RECOMBINATION_BY_SAMPLE.get(sample, False)


def _gard_mpi_procs():
    explicit = _coerce_int(config.get("gard_mpi_procs"))
    if explicit and explicit > 0:
        return explicit

    slurm_cpus = _coerce_int(os.environ.get("SLURM_CPUS_PER_TASK"))
    if slurm_cpus and slurm_cpus > 0:
        return slurm_cpus

    return 8


def _slurm_mem_mb():
    per_node = _coerce_int(os.environ.get("SLURM_MEM_PER_NODE"))
    if per_node:
        return per_node

    per_cpu = _coerce_int(os.environ.get("SLURM_MEM_PER_CPU"))
    cpus = _coerce_int(os.environ.get("SLURM_CPUS_PER_TASK"))
    if per_cpu and cpus:
        return per_cpu * cpus

    return None


def _macse_requested_mem_mb():
    explicit = _coerce_int(config.get("macse_mem_mb"))
    if explicit:
        return explicit
    return _slurm_mem_mb() or MACSE_MIN_HEAP_MB


def _macse_heap_mb():
    explicit_heap = _coerce_int(config.get("macse_heap_mb"))
    if explicit_heap:
        return explicit_heap

    requested = _macse_requested_mem_mb()
    baseline = min(MACSE_MIN_HEAP_MB, requested)
    heap_from_fraction = int(requested * MACSE_HEAP_FRACTION)
    heap_after_reserve = requested - MACSE_HEAP_RESERVE_MB
    usable = min(heap_from_fraction, heap_after_reserve) if heap_after_reserve > 0 else heap_from_fraction
    return max(baseline, min(requested, usable))


samples_df = pd.read_csv(SAMPLES_CSV).copy()
required = {"sample", "codon_fasta", "sequence_labels_csv"}
missing = required.difference(samples_df.columns)
if missing:
    raise ValueError(f"samples.csv missing required columns {sorted(missing)}")

samples_df["sample"] = samples_df["sample"].astype(str)

SAMPLES = samples_df["sample"].tolist()
CODON_FASTA_BY_SAMPLE = dict(zip(samples_df["sample"], samples_df["codon_fasta"].astype(str)))
LABELS_CSV_BY_SAMPLE = dict(zip(samples_df["sample"], samples_df["sequence_labels_csv"].astype(str)))
if "run_recombination" in samples_df.columns:
    RECOMBINATION_BY_SAMPLE = {
        sample: _coerce_bool(value, default=False)
        for sample, value in zip(samples_df["sample"], samples_df["run_recombination"])
    }
else:
    default_recombination = _coerce_bool(config.get("run_recombination", False), default=False)
    RECOMBINATION_BY_SAMPLE = {sample: default_recombination for sample in SAMPLES}


def codon_fasta_path(sample):
    return os.path.join(BASEDIR, CODON_FASTA_BY_SAMPLE[sample])


def labels_csv_path(sample):
    value = LABELS_CSV_BY_SAMPLE.get(sample, None)
    if _is_missing(value):
        return ""
    return os.path.join(BASEDIR, str(value))


SAMPLES_WITH_LABELS = [
    sample for sample in SAMPLES
    if (not _is_missing(LABELS_CSV_BY_SAMPLE.get(sample, None))) and os.path.exists(labels_csv_path(sample))
]


